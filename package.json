{
	"name": "ofetch-presets-monorepo",
	"type": "module",
	"private": true,
	"packageManager": "pnpm@11.9.0",
	"author": "zhong666 <hi@zhong666.me>",
	"license": "MIT",
	"scripts": {
		"build": "pnpm -r run build",
		"bench": "vitest bench --run",
		"release": "pnpm -r --workspace-concurrency=1 run release",
